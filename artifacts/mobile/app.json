{
  "expo": {
    "name": "Anchored Mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3EF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anchored.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Anchored uses the camera so you can capture a photo as proof that you completed a daily anchor.",
        "NSPhotoLibraryUsageDescription": "Anchored needs access to your photos so you can attach an existing image as proof for a daily anchor.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.anchored.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#3B82F6"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Anchored uses the camera so you can capture a photo as proof that you completed a daily anchor.",
          "photosPermission": "Anchored needs access to your photos so you can attach an existing image as proof for a daily anchor."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
